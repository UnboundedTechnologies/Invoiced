{
  "name": "invoiced",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-user toolbox for Unbounded Technologies Inc.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "seed": "tsx --env-file=.env.local src/lib/db/seed.ts",
    "set-password": "tsx --env-file=.env.local scripts/set-password.ts",
    "reset-password": "tsx --env-file=.env.local scripts/reset-password.ts",
    "reset-vault-pin": "tsx --env-file=.env.local scripts/reset-vault-pin.ts",
    "optimize-logo": "tsx scripts/optimize-logo.ts",
    "optimize-banner": "tsx scripts/optimize-banner.ts",
    "cleanup-blobs": "tsx --env-file=.env.local scripts/cleanup-blobs.ts",
    "cleanup-phantom-docs": "tsx --env-file=.env.local scripts/cleanup-phantom-docs.ts",
    "backfill-paycheques-2026": "tsx --env-file=.env.local scripts/backfill-paycheques-2026.ts",
    "verify-math": "tsx scripts/verify-invoice-math.ts",
    "verify-loans": "tsx scripts/verify-loans.ts",
    "verify-hst": "tsx scripts/verify-hst.ts",
    "verify-dashboard": "tsx scripts/verify-dashboard.ts",
    "verify-coherence": "tsx scripts/verify-coherence.ts",
    "verify-payroll": "tsx scripts/verify-payroll.ts",
    "verify-deadlines": "tsx scripts/verify-deadlines.ts",
    "verify-vault": "tsx scripts/verify-vault.ts",
    "verify-vault-pin": "tsx --env-file=.env.local scripts/verify-vault-pin.ts",
    "verify-t2": "tsx scripts/verify-t2.ts",
    "verify-t1": "tsx scripts/verify-t1.ts",
    "verify-planner": "tsx scripts/verify-planner.ts",
    "verify-all": "pnpm verify-math && pnpm verify-loans && pnpm verify-hst && pnpm verify-dashboard && pnpm verify-payroll && pnpm verify-deadlines && pnpm verify-vault && pnpm verify-vault-pin && pnpm verify-t2 && pnpm verify-t1 && pnpm verify-planner && pnpm verify-coherence",
    "gen-tax-pdf": "tsx scripts/gen-tax-pdf.tsx"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@neondatabase/serverless": "^0.10.4",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@react-pdf/renderer": "^4.1.6",
    "@vercel/blob": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.469.0",
    "next": "^15.1.4",
    "next-auth": "5.0.0-beta.30",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.5.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.0.5",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "@tailwindcss/oxide",
      "unrs-resolver",
      "esbuild"
    ]
  }
}
