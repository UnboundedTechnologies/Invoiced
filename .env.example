# ────────────────────────────────────────────────────────────
# Invoiced — environment template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ────────────────────────────────────────────────────────────

# ─── Database (Neon Postgres, pooled connection) ───
# Get from: https://console.neon.tech → your project → Connection Details → Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth.js v5 ───
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET="REPLACE_WITH_32_BYTE_RANDOM"

# Public app URL. In dev use http://localhost:3000. In prod set to your Vercel URL.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Comma-separated allowlist of login emails. First entry is the admin —
# it's the only email that can bootstrap itself from ADMIN_PASSWORD_HASH on
# first login. Additional entries are test/visitor accounts; create their
# users rows explicitly via:  pnpm set-password <email>
# Legacy ALLOWED_LOGIN_EMAIL (singular) is still honored as a fallback.
ALLOWED_LOGIN_EMAILS="unboundedtechnologies@gmail.com"

# Argon2id hash of the admin password. Generate via: pnpm set-password
# DO NOT store the plaintext password anywhere.
ADMIN_PASSWORD_HASH=""

# ─── Vercel Blob (Private mode store) ───
# IMPORTANT: provision a Private-mode Blob store, not Public.
# Get from: Vercel project → Storage → Create Database → Blob → Private → .env tab.
# All 6 /api/.../route.ts proxies stream via SDK get() — no public URL exposure.
BLOB_READ_WRITE_TOKEN=""

# ─── 2FA / TOTP encryption ───
# AES-256-GCM key for the totp_secret_encrypted column. Generate via:
#   openssl rand -base64 32
# Rotating this invalidates every enrolled secret in the DB — see § 1.4 of
# SECURITY_RUNBOOK.md for the rotation procedure.
TOTP_ENCRYPTION_KEY=""

# ─── Web Push (PWA notifications) ───
# Generate a fresh keypair via:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is bundled into client JS (NEXT_PUBLIC_ prefix). Private key
# stays server-side. Subject is a contact mailto: for Apple/Google push
# operators. Required in prod for the daily deadline-push cron to fire;
# optional in dev (no push without these).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"

# ─── Cron auth ───
# Vercel auto-injects this on first deploy with vercel.json crons configured.
# Only needed in .env.local for testing the cron route manually:
#   curl -H "Authorization: Bearer $CRON_SECRET" http://localhost:3000/api/cron/deadline-push
CRON_SECRET=""

# ─── Login rate-limiting (Upstash; Redis-protocol / Valkey-compatible) ───
# REQUIRED in production. When unset, src/lib/rate-limit.ts is a no-op,
# which is fine for local dev.
# Get from: console.upstash.com → DB details → REST API section.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
