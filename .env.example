# ────────────────────────────────────────────────────────────
# Invoiced — environment template
# Copy to .env.local and fill in. NEVER commit .env.local.
# ────────────────────────────────────────────────────────────

# ─── Database (Neon Postgres, pooled connection) ───
# Get from: https://console.neon.tech → your project → Connection Details → Pooled connection
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# ─── Auth.js v5 ───
# Generate with: openssl rand -base64 32   (or: npx auth secret)
AUTH_SECRET="REPLACE_WITH_32_BYTE_RANDOM"

# Public app URL. In dev use http://localhost:3000. In prod set to your Vercel URL.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Single-user lockdown — only this email can log in.
ALLOWED_LOGIN_EMAIL="unboundedtechnologies@gmail.com"

# Argon2id hash of the admin password. Generate via: pnpm set-password
# DO NOT store the plaintext password anywhere.
ADMIN_PASSWORD_HASH=""

# ─── Vercel Blob (encrypted private file storage) ───
# Get from: Vercel project → Storage → Connect Store → Blob → .env tab
BLOB_READ_WRITE_TOKEN=""

# ─── Optional: Upstash Redis for rate limiting on /login ───
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
